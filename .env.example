# MongoDB Atlas connection string
# IMPORTANT: Use plain ampersands (&), not HTML &amp;, and do not include markdown/mailto brackets.
# Change <PASSWORD> to your MongoDB Atlas database user password.
MONGODB_URI="mongodb+srv://dexterlambbb_db_user:<PASSWORD>@cluster0.wdrok43.mongodb.net/pos_system?retryWrites=true&w=majority&appName=Cluster0"

# New database name for this POS system.
# MongoDB Atlas will auto-create this database after you click Seed menu or save the first order.
MONGODB_DB="pos_system"

# Optional old alias also supported by the app. Use only one if you want.
# POS_DB_NAME="pos_system"

